# ─── Required ──────────────────────────────────────────────────────────
# Anthropic API key — used by /api/parse-menu to call Claude vision.
# Get one at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=

# Upstash Redis — group-order state lives here (one JSON key per room, 24h TTL).
# These exact names match what Vercel sets when you add Upstash Redis from
# Storage → Marketplace. Alternative names UPSTASH_REDIS_REST_URL /
# UPSTASH_REDIS_REST_TOKEN are also accepted (direct Upstash project).
KV_REST_API_URL=
KV_REST_API_TOKEN=
